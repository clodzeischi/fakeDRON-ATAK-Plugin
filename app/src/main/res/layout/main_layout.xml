<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- ── HEADER ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:drawableStart="@drawable/icon_drone"
            android:drawablePadding="8dp"
            android:text="@string/app_name"
            android:textColor="@color/header"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center_vertical"
            android:paddingBottom="12dp" />

        <!-- ── STATUS CHIP ── -->
        <TextView
            android:id="@+id/tv_drone_state"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:text="@string/label_status_idle"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:textStyle="bold" />

        <!-- ── PRIMARY ACTIONS ── -->
        <LinearLayout
            style="?android:attr/buttonBarStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <Button
                android:id="@+id/btn_launch_land"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="@string/label_btn_launch"
                android:textColor="@color/text_primary"
                android:backgroundTint="#2E7D32"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_rth"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="@string/label_btn_rth"
                android:textColor="@color/text_primary"
                android:backgroundTint="#B71C1C"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- ── ALTITUDE SECTION ── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_altitude"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="6dp" />

        <!-- Target row: label + slider + value -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:text="@string/label_target"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <SeekBar
                android:id="@+id/sb_target_altitude"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="8dp" />

            <TextView
                android:id="@+id/tv_target_altitude"
                android:layout_width="44dp"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:gravity="end" />

        </LinearLayout>

        <!-- Actual row: label + spacer + value -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:text="@string/label_actual"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="8dp"
                android:background="#333333" />

            <TextView
                android:id="@+id/tv_actual_altitude"
                android:layout_width="44dp"
                android:layout_height="wrap_content"
                android:text="@string/label_blank_alt"
                android:textColor="@color/text_tertiary"
                android:textSize="13sp"
                android:gravity="end" />

        </LinearLayout>

        <!-- ── FLY TO MAP POINT ── -->
        <Button
            android:id="@+id/btn_goto"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="20dp"
            android:text="@string/label_btn_goto"
            android:textColor="@color/text_primary"
            android:backgroundTint="@color/background_btn"
            android:textStyle="bold" />

        <!-- ── LOCATION ── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_drone_location"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/tv_mgrs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_blank_location"
            android:textColor="@color/text_tertiary"
            android:textSize="16sp"
            android:fontFamily="monospace"
            android:paddingVertical="8dp" />

    </LinearLayout>
</ScrollView>